# Normalize line endings for all text files to LF in the repository.
# Git will convert to the OS native ending on checkout (CRLF on Windows).
* text=auto

*.h          text eol=lf
*.cpp        text eol=lf
*.ino        text eol=lf
*.md         text eol=lf
*.txt        text eol=lf
*.properties text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.sh         text eol=lf
*.bat        text eol=crlf
*.ps1        text eol=crlf

# Binary files — never touch line endings
*.png  binary
*.jpg  binary
*.gif  binary
